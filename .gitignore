# ============================================================
# Memora (Samsung Anchor) - .gitignore
# ============================================================

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# ------------------------------------------------------------
# macOS
# ------------------------------------------------------------
.DS_Store

# ------------------------------------------------------------
# Virtual Environments
# ------------------------------------------------------------
.env
.env.*
venv/
.venv/
env/
ENV/

# ------------------------------------------------------------
# Python Build & Packaging
# ------------------------------------------------------------
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# ------------------------------------------------------------
# Pytest / Coverage
# ------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.cache/

# ------------------------------------------------------------
# IDEs
# ------------------------------------------------------------
.vscode/
.idea/

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
*.log
logs/

# ------------------------------------------------------------
# Databases
# ------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
*.db-journal

# Runtime-generated database files
face_embeddings.index
face_mapping.json

# Temporary JSON data
*.old_json

# ------------------------------------------------------------
# Machine Learning Models
# ------------------------------------------------------------
*.pt
*.pth
*.onnx
checkpoints/
weights/

# ------------------------------------------------------------
# Runtime / Deployment
# ------------------------------------------------------------
tmp/
temp/
runtime/
*.pid

# ------------------------------------------------------------
# Docker
# ------------------------------------------------------------
docker-data/

# ------------------------------------------------------------
# Accidental SQLite Artifacts
# ------------------------------------------------------------
sqlite/

# ------------------------------------------------------------
# Jupyter
# ------------------------------------------------------------
.ipynb_checkpoints/

# ------------------------------------------------------------
# OS Generated
# ------------------------------------------------------------
Thumbs.db

# ------------------------------------------------------------
# Miscellaneous
# ------------------------------------------------------------
*.swp
*.swo